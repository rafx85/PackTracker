<ComboBox x:Class="PackTracker.Controls.PackDropDown"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:view="clr-namespace:PackTracker.View"
          DataContextChanged="dd_Packs_DataContextChanged"
          DropDownOpened="dd_Packs_DropDownOpened"
          DropDownClosed="dd_Packs_DropDownClosed"
          MouseWheel="dd_Packs_MouseWheel"
          x:Name="dd_Packs"
          VerticalAlignment="Center"
          IsEditable="True"
          IsTextSearchEnabled="False"
          StaysOpenOnEdit="True"
          ToolTip="Type to filter sets by name or ID"
          IsEnabled="{Binding Items.Count, Mode=OneWay, RelativeSource={RelativeSource Self}}">
    <ComboBox.Resources>
        <view:PackNameConverter x:Key="PackNameConverter"/>
    </ComboBox.Resources>
    <ComboBox.ItemTemplate>
        <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource PackNameConverter}}"/>
        </DataTemplate>
    </ComboBox.ItemTemplate>
</ComboBox>
